# =============================================================================
# NativeLayer AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to source control.
# =============================================================================

# --- Database ---
# Local: matches docker-compose.yml defaults
DATABASE_URL=postgresql://nativelayer:secret@localhost:5432/nativelayer

# --- Encryption ---
# 32-byte hex key used for AES-256-GCM encryption of Shopify tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Dashboard Session (iron-session) ---
# Minimum 32 characters, random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# --- Dashboard Admin Credentials ---
# Single admin user for MVP. Hash stored at startup; raw password only in env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
# Generate hash: node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');const h=c.scryptSync('yourpassword',s,64).toString('hex');console.log(s+':'+h)"

# --- API Server ---
API_PORT=3001
API_HOST=0.0.0.0

# --- Dashboard ---
DASHBOARD_PORT=3000
# Used by iron-session and CSRF checks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Security ---
# Set to 'true' to require HMAC-SHA256 request signing on all /ai/* calls.
REQUIRE_HMAC_SIGNING=false

# --- Rate Limiting ---
# Requests per minute per client key (default: 60)
RATE_LIMIT_RPM=60
# Requests per minute per merchant (default: 300)
RATE_LIMIT_MERCHANT_RPM=300

# --- Shopify (per-merchant — stored encrypted in DB, not here) ---
# These are only used when seeding a test merchant locally:
# SEED_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SEED_SHOPIFY_STOREFRONT_TOKEN=your-public-storefront-access-token
