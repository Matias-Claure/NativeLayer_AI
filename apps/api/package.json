    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.3.3",
    "@nativelayer/schemas": "*",
    "@nativelayer/security": "*",
    "@nativelayer/observability": "*",
    "@nativelayer/shopify-client": "*",
    "drizzle-orm": "^0.41.0",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
